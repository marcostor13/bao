---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="BA Organization — Curating Homes, Cultivating Wellness. Luxury home organization in Georgia.">

  <!-- ── HERO ──────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-container">
      <div class="hero-card">
        <h1 class="hero-title">
          CURATING HOMES.<br />
          <span class="text-gold">CULTIVATING WELLNESS.</span>
        </h1>
        <div class="divider-gold" style="margin: 20px 0; width: 60px;"></div>
        <p class="hero-sub">
          We transform chaotic spaces into harmonious sanctuaries using
          sustainable organization systems and non-toxic living principles.
        </p>
        <a href="/contact-us" class="btn-gold">Start Your Transformation &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ── VALUE PROPOSITION ─────────────────────────────────────── -->
  <section class="section-light value-prop">
    <div class="container text-center">
      <div class="value-header">
        <img src="/images/SVG/Recurso 2bao_.svg" alt="BAO Icon" class="mx-auto mb-4" style="width:60px;height:auto;" />
        <h2 class="value-prop-title mb-6">
          <span class="value-word-value">VALUE</span> <span class="value-word-proposition">PROPOSITION</span>
        </h2>
      </div>
      
      <p class="value-quote">
        <strong>Your home should tell the story of who you are,</strong> and be a collection of what you
        love. We don't just tidy up; we implement intuitive systems that calm your nervous
        system and protect your family's health.
      </p>

      <div class="value-cards">
        <!-- Card 1 -->
        <div class="value-card-wrapper">
          <div class="value-card-image" style="background-image:url('/images/fotos2/BV4A9011-57.webp')">
            <div class="value-card-overlay">
              <p class="card-overlay-title">SERVICE<br/>HIGHLIGHTS</p>
            </div>
          </div>
          <div class="value-card-content">
            <h3 class="card-content-title">Bespoke Organization:</h3>
            <p class="card-content-text">
              Custom solutions for every closet, pantry, and room.
            </p>
            <div class="mt-4">
              <h3 class="card-content-title">Wellness Cleaning:</h3>
              <p class="card-content-text">
                A 100% non-toxic approach to a spotless home.
              </p>
            </div>
             <div class="mt-4">
              <h3 class="card-content-title">Relocation Concierge:</h3>
              <p class="card-content-text">
                Move in, unpack, and settle in effortlessly.
              </p>
            </div>
            <a href="/contact-us" class="btn-card mt-6">BOOK NOW</a>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="value-card-wrapper">
          <div class="value-card-image" style="background-image:url('/images/fotos2/IMG_9262.webp')">
            <div class="value-card-overlay">
              <p class="card-overlay-title">THE BA<br/>DIFFERENCE</p>
            </div>
          </div>
          <div class="value-card-content">
            <h3 class="card-content-title">"Where Feng Shui meets Functional Design."</h3>
            <a href="/contact-us" class="btn-card mt-6">BOOK NOW</a>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="value-card-wrapper">
          <div class="value-card-image" style="background-image:url('/images/fotos2/BV4A8736-10.webp')">
            <div class="value-card-overlay">
              <p class="card-overlay-title">SOCIAL PROOF</p>
            </div>
          </div>
          <div class="value-card-content">
            <p class="card-content-text">
              Join families across Georgia reclaiming their time and peace.
            </p>
            <a href="/contact-us" class="btn-card mt-6">BOOK NOW</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── OUR PHILOSOPHY ─────────────────────────────────────────── -->
  <section class="section-navy philosophy">
    <div class="philosophy-bg"></div>
    <div class="philosophy-overlay"></div>
    <div class="container text-center relative z-10">
      <div class="philosophy-header mb-12">
        <img src="/images/1x/Recurso 1bao_.webp" alt="Icon" class="mx-auto mb-4 w-12 h-12 opacity-80" />
        <h2 class="section-title-light mb-2" style="font-family:'Cinzel',serif; color:#d5ad7f;">OUR PHILOSOPHY</h2>
        <p class="section-label tracking-widest text-sm" style="font-family:'Cinzel',serif; color:#fff; font-size:1.1rem; letter-spacing:0.28em;">THE 3 PILLARS</p>
      </div>

      <div class="pillars">
        <div class="pillar">
          <div class="pillar-img-wrapper">
            <div class="pillar-img" style="background-image:url('/images/fotos2/IMG_9260.webp')"></div>
          </div>
          <div class="pillar-content">
            <span class="pillar-num">01.</span>
            <h3 class="pillar-title">Esthetics:</h3>
            <p class="pillar-text">Beautiful spaces inspire creativity and calm.</p>
          </div>
        </div>
        <div class="pillar">
          <div class="pillar-img-wrapper">
            <div class="pillar-img" style="background-image:url('/images/pillar-2.webp')"></div>
          </div>
          <div class="pillar-content">
            <span class="pillar-num">02.</span>
            <h3 class="pillar-title">Function:</h3>
            <p class="pillar-text">Systems must be intuitive to be sustainable.</p>
          </div>
        </div>
        <div class="pillar">
          <div class="pillar-img-wrapper">
            <div class="pillar-img" style="background-image:url('/images/pillar-3.webp')"></div>
          </div>
          <div class="pillar-content">
            <span class="pillar-num">03.</span>
            <h3 class="pillar-title">Wellness:</h3>
            <p class="pillar-text">A clean home shouldn't come at the cost of your health.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SERVICES ───────────────────────────────────────────────── -->
  <section class="section-light services-section">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="section-title services-title mt-2">Services</h2>
        <p class="services-sub">Comprehensive solutions for the modern, conscious home.</p>
      </div>

      <!-- Service 1 -->
      <div class="service-row">
        <div class="service-text">
          <img src="/images/SVG/SVG/service1bao_.svg" alt="Service 1 Icon" class="service-icon" />
          <h3 class="service-title">SERVICE 1</h3>
          <p class="service-headline">LUXURY HOME ORGANIZATION</p>
          <div class="service-desc-block">
            <p class="service-desc">
              <strong>Description:</strong> We edit, categorize, and style your space.
              Whether it's a boutique-style closet or a chef-worthy
              pantry, we create systems that stick.
            </p>
            <p class="service-includes">
              <strong>Includes:</strong> Wardrobes, Kitchens, Playrooms, Garages,
              Home Offices.
            </p>
          </div>
          <a href="/contact-us" class="btn-card mt-6">BOOK NOW</a>
        </div>
        <div class="service-img" style="background-image:url('/images/fotos2/BV4A8736-10.webp')"></div>
      </div>

      <!-- Service 2 -->
      <div class="service-row reverse">
        <div class="service-img" style="background-image:url('/images/value-prop-3.webp')"></div>
        <div class="service-text">
          <img src="/images/SVG/SVG/service2bao_.svg" alt="Service 2 Icon" class="service-icon" />
          <h3 class="service-title">SERVICE 2</h3>
          <p class="service-headline">NON-TOXIC WELLNESS CLEANING</p>
          <div class="service-desc-block">
            <p class="service-headline-sub"><strong>Headline:</strong> Clean Home, Clear Conscience.</p>
            <p class="service-desc">
              <strong>Description:</strong> Traditional cleaning products are laden with
              VOCs and endocrine disruptors. We use only plant-based,
              mineral-rich formulas that are safe for babies, pets, and
              your air quality.
            </p>
            <p class="service-note">
              <strong>The "No" List:</strong> No Bleach. No Ammonia. No Synthetic
              Fragrances. No Phthalates.
            </p>
          </div>
          <a href="/contact-us" class="btn-card mt-6">BOOK NOW</a>
        </div>
      </div>

      <!-- Service 3 -->
      <div class="service-row">
        <div class="service-text">
          <img src="/images/SVG/SVG/service3bao_.svg" alt="Service 3 Icon" class="service-icon" />
          <h3 class="service-title">SERVICE 3</h3>
          <p class="service-headline">MOVE-IN CONCIERGE</p>
          <div class="service-desc-block">
            <p class="service-headline-sub"><strong>Headline:</strong> Walk Into a "Done" Home.</p>
            <p class="service-desc">
              <strong>Description:</strong> Skip the weeks of living out of boxes. We
              manage your entire unpacking process, organizing your
              belongings from Day 1 so you can start living immediately.
            </p>
          </div>
          <a href="/contact-us" class="btn-card mt-6">BOOK NOW</a>
        </div>
        <div class="service-img" style="background-image:url('/images/value-prop-2.webp')"></div>
      </div>

      <!-- Service 4 -->
      <div class="service-row reverse">
        <div class="service-img" style="background-image:url('/images/fotos2/BV4A9011-57.webp')"></div>
        <div class="service-text">
          <img src="/images/SVG/SVG/service4bao_.svg" alt="Service 4 Icon" class="service-icon" />
          <h3 class="service-title">SERVICE 4</h3>
          <p class="service-headline">SEASONAL REFRESH & MAINTENANCE</p>
          <div class="service-desc-block">
            <p class="service-desc">
              <strong>Description:</strong> As seasons change, so do your needs. We
              return to edit wardrobes, refresh systems, and deep clean
              to keep your sanctuary pristine.
            </p>
          </div>
          <a href="/contact-us" class="btn-card mt-6">BOOK NOW</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── THE PROCESS ────────────────────────────────────────────── -->
  <section class="process-section">
    <div class="process-bg"></div>
    <div class="process-overlay"></div>
    <div class="container text-center relative z-10">
      <div class="process-header">
        <h2 class="process-title">THE PROCESS</h2>
        <div class="process-divider"></div>
      </div>

      <div class="process-grid">
        <!-- Step 1 -->
        <div class="process-step">
          <div class="process-icon-circle">
            <div class="process-icon-inner">
              <img src="/images/SVG/SVG/step1bao_.svg" alt="Step 1 icon" />
            </div>
          </div>
          <p class="process-step-num"><span class="step-label">STEP</span> 1.</p>
          <p class="process-step-title">
            DISCOVERY CALL
            <span class="process-step-title-muted">(COMPLIMENTARY)</span>
          </p>
          <p class="process-step-desc">
            We discuss your pain points, goals, and vision for the space.
          </p>
          <div class="process-step-underline"></div>
        </div>

        <!-- Step 2 -->
        <div class="process-step">
          <div class="process-icon-circle">
            <div class="process-icon-inner">
              <img src="/images/SVG/SVG/step2bao_.svg" alt="Step 2 icon" />
            </div>
          </div>
          <p class="process-step-num"><span class="step-label">STEP</span> 2.</p>
          <p class="process-step-title">
            THE ASSESSMENT<br/>&amp; STRATEGY
          </p>
          <p class="process-step-desc">
            In-home walkthrough to measure, plan, and design a custom layout
            that respects Feng Shui principles.
          </p>
          <div class="process-step-underline"></div>
        </div>

        <!-- Step 3 -->
        <div class="process-step">
          <div class="process-icon-circle">
            <div class="process-icon-inner">
              <img src="/images/SVG/SVG/step3bao_.svg" alt="Step 3 icon" />
            </div>
          </div>
          <p class="process-step-num"><span class="step-label">STEP</span> 3.</p>
          <p class="process-step-title">
            THE EDIT &amp;<br/>DETOX
          </p>
          <p class="process-step-desc">
            We help you declutter what no longer serves you and remove toxic
            products from your environment.
          </p>
          <div class="process-step-underline"></div>
        </div>

        <!-- Step 4 -->
        <div class="process-step">
          <div class="process-icon-circle">
            <div class="process-icon-inner">
              <img src="/images/SVG/SVG/step4bao_.svg" alt="Step 4 icon" />
            </div>
          </div>
          <p class="process-step-num"><span class="step-label">STEP</span> 4.</p>
          <p class="process-step-title">
            INSTALLATION &amp;<br/>ORGANIZATION
          </p>
          <p class="process-step-desc">
            Our team implements the systems, installs storage solutions, and
            styles every shelf to perfection.
          </p>
          <div class="process-step-underline"></div>
        </div>

        <!-- Step 5 -->
        <div class="process-step">
          <div class="process-icon-circle">
            <div class="process-icon-inner">
              <img src="/images/SVG/SVG/step5bao_.svg" alt="Step 5 icon" />
            </div>
          </div>
          <p class="process-step-num"><span class="step-label">STEP</span> 5.</p>
          <p class="process-step-title">
            THE REVEAL &amp;<br/>EDUCATION
          </p>
          <p class="process-step-desc">
            Walkthrough of your new space with tips on how to maintain the
            order effortlessly.
          </p>
          <div class="process-step-underline"></div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── THE WELLNESS STANDARD ─────────────────────────────────── -->
  <section class="wellness-section">
    <div class="container wellness-header">
      <h2 class="wellness-title">THE WELLNESS STANDARD</h2>
      <p class="wellness-subtitle">WHY NON-TOXIC MATTERS.</p>
    </div>
    <div class="container wellness-grid">
      <div class="wellness-col">
        <div class="wellness-col-icon">
          <img src="/images/SVG/SVG/contentbao_.svg" alt="" aria-hidden="true" />
        </div>
        <p class="wellness-col-title">CONTENT</p>
        <p class="wellness-col-text">
          <strong>The Problem:</strong> Indoor air quality can be 2-5x more polluted than outdoor air due to chemical cleaners.<br/>
          <strong>Our Solution:</strong> We use trusted brands like Branch Basics, Dr. Bronner's, and Blueland.
        </p>
      </div>
      <div class="wellness-col">
        <div class="wellness-col-icon">
          <img src="/images/SVG/SVG/theimpactbao_.svg" alt="" aria-hidden="true" />
        </div>
        <p class="wellness-col-title">THE IMPACT</p>
        <p class="wellness-col-text">
          <strong>Reducing chemical load helps balance hormones, improve sleep, and soothe the nervous system.</strong> <strong>Did You Know?</strong> "Fragrance" on a label can hide hundreds of undisclosed chemicals. We banish them all.
        </p>
      </div>
    </div>
  </section>

  <!-- ── PORTFOLIO ──────────────────────────────────────────────── -->
  <section class="portfolio-section">
    <div class="portfolio-bg"></div>
    <div class="portfolio-overlay"></div>
    <div class="relative z-10">

      <!-- Header -->
      <div class="container text-center">
        <div class="portfolio-header">
          <div class="portfolio-icon">
            <img src="/images/SVG/SVG/prtfoliobao_.svg" alt="" aria-hidden="true" />
          </div>
          <h2 class="portfolio-title">PORTFOLIO</h2>
          <p class="portfolio-sub">CATEGORIES</p>
        </div>
      </div>

      <!-- ── Category 1: Kitchens & Pantries ── -->
      <div class="pcat" data-pcat="kitchens">
        <div class="pcat-slider">
          <button class="pcat-arrow pcat-prev" aria-label="Previous">&#8249;</button>
          <div class="pcat-track">
            <div class="pcat-slide active">
              <div class="pcat-divider"></div>
              <h3 class="pcat-title">Kitchens &amp; Pantries</h3>
              <div class="pcat-ba-grid">
                <div class="pcat-ba-item">
                  <img src="/images/images2/bao-14.webp" alt="Kitchen Before" loading="lazy" />
                  <span class="pcat-ba-label">Before</span>
                </div>
                <div class="pcat-ba-item">
                  <img src="/images/images2/bao-15.webp" alt="Kitchen After" loading="lazy" />
                  <span class="pcat-ba-label">After</span>
                </div>
              </div>
            </div>
          </div><!-- /track -->
          <button class="pcat-arrow pcat-next" aria-label="Next">&#8250;</button>
        </div>
        <div class="pcat-dots"><span class="pcat-dot active"></span></div>
      </div>

      <!-- ── Category 2: Closets & Dressing Rooms ── -->
      <div class="pcat" data-pcat="closets">
        <div class="pcat-slider">
          <button class="pcat-arrow pcat-prev" aria-label="Previous">&#8249;</button>
          <div class="pcat-track">
            <div class="pcat-slide active">
              <div class="pcat-divider"></div>
              <h3 class="pcat-title">Closets &amp; Dressing Rooms</h3>
              <div class="pcat-ba-grid">
                <div class="pcat-ba-item">
                  <img src="/images/CLOSET_BEFORE.png" alt="Closet Before" loading="lazy" />
                  <span class="pcat-ba-label">Before</span>
                </div>
                <div class="pcat-ba-item">
                  <img src="/images/CLOSET_AFTER.jpg" alt="Closet After" loading="lazy" />
                  <span class="pcat-ba-label">After</span>
                </div>
              </div>
            </div>
          </div><!-- /track -->
          <button class="pcat-arrow pcat-next" aria-label="Next">&#8250;</button>
        </div>
        <div class="pcat-dots"><span class="pcat-dot active"></span></div>
      </div>

      <!-- ── Category 3: Playrooms & Kids Spaces ── -->
      <div class="pcat" data-pcat="playrooms">
        <div class="pcat-slider">
          <button class="pcat-arrow pcat-prev" aria-label="Previous">&#8249;</button>
          <div class="pcat-track">
            <div class="pcat-slide active">
              <div class="pcat-divider"></div>
              <h3 class="pcat-title">Playrooms &amp; Kids Spaces</h3>
              <div class="pcat-ba-grid">
                <div class="pcat-ba-item">
                  <img src="/images/images2/bao-18.webp" alt="Playroom Before" loading="lazy" />
                  <span class="pcat-ba-label">Before</span>
                </div>
                <div class="pcat-ba-item">
                  <img src="/images/images2/bao-19.webp" alt="Playroom After" loading="lazy" />
                  <span class="pcat-ba-label">After</span>
                </div>
              </div>
            </div>
          </div><!-- /track -->
          <button class="pcat-arrow pcat-next" aria-label="Next">&#8250;</button>
        </div>
        <div class="pcat-dots"><span class="pcat-dot active"></span></div>
      </div>

      <!-- ── Category 4: Bathrooms & Laundry ── -->
      <div class="pcat" data-pcat="bathrooms">
        <div class="pcat-slider">
          <button class="pcat-arrow pcat-prev" aria-label="Previous">&#8249;</button>
          <div class="pcat-track">
            <div class="pcat-slide active">
              <div class="pcat-divider"></div>
              <h3 class="pcat-title">Bathrooms &amp; Laundry</h3>
              <div class="pcat-ba-grid">
                <div class="pcat-ba-item">
                  <img src="/images/BARHDROOM_BEFORE.png" alt="Bathroom Before" loading="lazy" />
                  <span class="pcat-ba-label">Before</span>
                </div>
                <div class="pcat-ba-item">
                  <img src="/images/BATHDROOM_AFTER.jpg" alt="Bathroom After" loading="lazy" />
                  <span class="pcat-ba-label">After</span>
                </div>
              </div>
            </div>

          </div><!-- /track -->
          <button class="pcat-arrow pcat-next" aria-label="Next">&#8250;</button>
        </div>
        <div class="pcat-dots">
          <span class="pcat-dot active"></span>
        </div>
      </div>

    </div>
  </section>

  <!-- ── THE JOURNAL ────────────────────────────────────────────── -->
  <section class="journal-section">
    <div class="container">
      <div class="journal-header">
        <h2 class="journal-main-title">The Journal</h2>
        <p class="journal-main-sub">Sample Article Titles</p>
      </div>
      <div class="journal-grid">
        <article class="journal-card">
          <picture>
            <source srcset="/images/fotos2/bv4a8700-hdr-5.webp" type="image/webp" />
            <img
              src="/images/fotos2/bv4a8700-hdr-5.jpg"
              alt="Armario de cocina organizado con recipientes y botellas reutilizables"
              loading="lazy"
            />
          </picture>
          <div class="journal-card-overlay">
            <p class="journal-card-title">5 Hidden Toxins in Your Cleaning Cabinet (And What to Use Instead).</p>
          </div>
        </article>
        <article class="journal-card">
          <img src="/images/images2/bao-26.webp" alt="Journal post 2" loading="lazy"/>
          <div class="journal-card-overlay">
            <p class="journal-card-title">How to Organize a Pantry for Healthy Eating.</p>
          </div>
        </article>
        <article class="journal-card">
          <img src="/images/images2/bao-29.webp" alt="Journal post 3" loading="lazy"/>
          <div class="journal-card-overlay">
            <p class="journal-card-title">Feng Shui Basics: Clearing Energy in Your Bedroom.</p>
          </div>
        </article>
        <article class="journal-card">
          <img src="/images/images2/bao-30.webp" alt="Journal post 4" loading="lazy"/>
          <div class="journal-card-overlay">
            <p class="journal-card-title">5 Hidden Toxins in Your Cleaning Cabinet (And What to Use Instead).</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ── CONTACT FORM ─────────────────────────────────────────── -->
  <section class="hc-form-section">
    <div class="container">

      <div id="hcThankYou" class="hc-thank-you" aria-live="polite">
        <h3 class="hc-ty-title">Thank You!</h3>
        <p class="hc-ty-sub">We've received your inquiry and will be in touch within 24 hours.</p>
        <p class="hc-ty-contact">Questions? <a href="mailto:hello@baorganization.com">hello@baorganization.com</a> · <a href="tel:6787490931">(678) 749-0931</a></p>
      </div>

      <form id="hcForm" class="hc-form-wrapper" novalidate enctype="multipart/form-data">

        <!-- ── Header inside card ── -->
        <div class="hc-card-header">
          <div class="hc-card-header-inner">
            <img src="/images/SVG/1x/Recurso 20bao_.webp" alt="" class="hc-card-icon" aria-hidden="true" />
            <div class="hc-card-divider"></div>
            <div class="hc-card-header-text">
              <h2 class="hc-header-title">CONTACT</h2>
              <p class="hc-header-sub">Ready to Reclaim Your Space?</p>
            </div>
          </div>
        </div>

        <!-- Quick selects -->
        <div class="hc-quick-row">
          <div class="hc-group">
            <label class="hc-label" for="hc-service">Which service are you interested in?</label>
            <select id="hc-service" name="service" class="field" required>
              <option value="">Select a service</option>
              <option>Kitchen / Pantry</option>
              <option>Primary Closet</option>
              <option>Kids / Playroom</option>
              <option>Home Office</option>
              <option>Move-in Concierge</option>
              <option>Other</option>
            </select>
            <span class="hc-err" id="hcerr-service"></span>
          </div>
          <div class="hc-group">
            <label class="hc-label" for="hc-timeline">What is your timeline?</label>
            <select id="hc-timeline" name="timeline" class="field" required>
              <option value="">Select a timeline</option>
              <option>ASAP</option>
              <option>Within 1 month</option>
              <option>1–3 months</option>
              <option>3–6 months</option>
            </select>
