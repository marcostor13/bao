</style>

<script>
  // ── Home Contact Form ──────────────────────────────────────────────────────
  const hcPhotoInput = document.getElementById('hcPhotoUpload') as HTMLInputElement;
  const hcFileList   = document.getElementById('hcFileList') as HTMLDivElement;
  hcPhotoInput?.addEventListener('change', () => {
    const files = Array.from(hcPhotoInput.files ?? []);
    hcFileList.textContent = files.map(f => `${f.name} (${(f.size/1024).toFixed(0)} KB)`).join('\n');
  });

  function hcSetError(fieldId: string, msg: string) {
    const field = document.getElementById(fieldId);
    const errEl = document.getElementById(`hcerr-${fieldId.replace('hc-','')}`);
    field?.classList.add('hc-field-error');
    if (errEl) errEl.textContent = msg;
  }
  function hcClearError(fieldId: string) {
    const field = document.getElementById(fieldId);
    const errEl = document.getElementById(`hcerr-${fieldId.replace('hc-','')}`);
    field?.classList.remove('hc-field-error');
    if (errEl) errEl.textContent = '';
  }

  const hcForm      = document.getElementById('hcForm') as HTMLFormElement;
  const hcSubmitBtn = document.getElementById('hcSubmitBtn') as HTMLButtonElement;
  const hcStatusEl  = document.getElementById('hcStatus') as HTMLDivElement;
  const hcThankYou  = document.getElementById('hcThankYou') as HTMLDivElement;

  hcForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    ['hc-service','hc-timeline','hc-fullName','hc-email','hc-phone','hc-address','hc-goals'].forEach(hcClearError);
    const errSpaces = document.getElementById('hcerr-spaces');
    if (errSpaces) errSpaces.textContent = '';
    hcStatusEl.className = '';
    hcStatusEl.style.display = 'none';

    let hasError = false;
    const val = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement)?.value.trim() ?? '';

    if (!val('hc-service'))  { hcSetError('hc-service',  'Please select a service.');  hasError = true; }
    if (!val('hc-timeline')) { hcSetError('hc-timeline', 'Please select a timeline.'); hasError = true; }
    if (!val('hc-fullName')) { hcSetError('hc-fullName', 'Full name is required.');    hasError = true; }

    const emailVal = val('hc-email');
    if (!emailVal) { hcSetError('hc-email', 'Email is required.'); hasError = true; }
    else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) { hcSetError('hc-email', 'Enter a valid email.'); hasError = true; }

    const phoneVal = val('hc-phone');
    if (!phoneVal) { hcSetError('hc-phone', 'Phone is required.'); hasError = true; }
    else if (!/^\+?[\d\s\-().]{7,20}$/.test(phoneVal)) { hcSetError('hc-phone', 'Enter a valid phone number.'); hasError = true; }

    if (!val('hc-address')) { hcSetError('hc-address', 'Project address is required.'); hasError = true; }
    if (!val('hc-goals'))   { hcSetError('hc-goals',   'Please describe your primary goals.'); hasError = true; }

    const spaces = Array.from(document.querySelectorAll<HTMLInputElement>('#hcForm input[name="spaces[]"]:checked'));
    if (spaces.length === 0) { if (errSpaces) errSpaces.textContent = 'Select at least one space.'; hasError = true; }

    if (hasError) {
      hcForm.querySelector<HTMLElement>('.hc-field-error')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      hcStatusEl.textContent = 'Please correct the highlighted fields.';
      hcStatusEl.className   = 'hc-status-error';
      hcStatusEl.style.display = 'block';
      return;
    }

    hcSubmitBtn.disabled    = true;
    hcSubmitBtn.textContent = 'Sending…';

    try {
      const formData = new FormData(hcForm);
      const res  = await fetch('/api/contact.php', { method: 'POST', body: formData });
      const data = await res.json();
      if (data.success) {
        hcForm.style.display = 'none';
        hcThankYou.classList.add('visible');
        hcThankYou.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        hcStatusEl.textContent  = data.message ?? 'Something went wrong. Please try again.';
        hcStatusEl.className    = 'hc-status-error';
        hcStatusEl.style.display = 'block';
        hcSubmitBtn.disabled    = false;
        hcSubmitBtn.innerHTML   = 'Start Your <em>Transformation</em>';
      }
    } catch {
      hcStatusEl.textContent  = 'Network error. Please try again or call (678) 749-0931.';
      hcStatusEl.className    = 'hc-status-error';
      hcStatusEl.style.display = 'block';
      hcSubmitBtn.disabled    = false;
      hcSubmitBtn.innerHTML   = 'Start Your <em>Transformation</em>';
    }
  });

  // ── Portfolio sliders ──────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.pcat').forEach(cat => {
    const slides = Array.from(cat.querySelectorAll<HTMLElement>('.pcat-slide'));
    const dots   = Array.from(cat.querySelectorAll<HTMLElement>('.pcat-dot'));
    if (slides.length <= 1) { cat.dataset.single = ''; return; }

    let cur = 0;

    function goTo(idx: number) {
      slides[cur].classList.remove('active');
      dots[cur]?.classList.remove('active');
      cur = (idx + slides.length) % slides.length;
      slides[cur].classList.add('active');
      dots[cur]?.classList.add('active');
    }

    cat.querySelector('.pcat-prev')?.addEventListener('click', () => goTo(cur - 1));
    cat.querySelector('.pcat-next')?.addEventListener('click', () => goTo(cur + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
  });
</script>
