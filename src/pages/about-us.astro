---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us" description="Meet Monica Avila & Beatriz Miranda — founders of BA Organization.">

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-container">
      <div class="hero-card">
        <h1 class="hero-title">
          MORE THAN ORGANIZATION.<br />
          <span class="text-gold">A LIFESTYLE RESET.</span>
        </h1>
      </div>
    </div>
  </section>

  <!-- ── HELLO & WELCOME ── -->
  <section class="hello-section">
    <div class="hello-grid">
      <div class="hello-img">
        <picture>
          <source srcset="/images/fotos2/IMG_6280.webp" type="image/webp" />
          <img
            src="/images/fotos2/IMG_6280.JPG"
            alt="Organización de despensa en cocina luminosa"
            loading="lazy"
          />
        </picture>
      </div>
      <div class="hello-text">
        <h2 class="hello-title">Hello &amp; Welcome!</h2>
        <p class="hello-sub">We're Monica Avila &amp; Beatriz Miranda.</p>

        <div class="hello-icon">
          <img src="/images/SVG/1x/Recurso 24bao_.webp" alt="" aria-hidden="true" class="hello-icon-img" />
        </div>

        <p class="hello-body">
          We created the BA Organization because we believe your home should be your sanctuary, a
          place where the noise of the world fades away, and your nervous system can finally rest.
        </p>
        <p class="hello-body">
          Our journey didn't start in a boardroom or with a business plan. It started right at home,
          in the middle of the beautiful chaos of raising our kids. As mothers, we both experienced
          the same frustration: no matter how much we cleaned and organized, something always felt off.
          Our spaces didn't support the calm our families needed, and the products we trusted to
          keep our homes fresh were often silently harming us.
        </p>
        <p class="hello-body">
          When we connected and shared our stories, we realized we weren't alone and that we could
          do something about it. We combined Monica's eye for functional design with Beatriz's
          passion for non-toxic, intentional living, and BA Organization was born.
        </p>
        <p class="hello-body">
          Today, we don't just organize stuff. We curate environments that support your health,
          elevate your daily rituals, and bring a profound sense of peace to your family because
          every home deserves to feel like a true sanctuary.
        </p>
      </div>
    </div>
  </section>

  <!-- ── OUR CORE VALUES ── -->
  <section class="section-values">
    <div class="values-image-left">
      <img src="/images/images2/bao-22.webp" alt="Home organization" loading="lazy" />
    </div>

    <div class="values-center">
      <h2 class="values-title">OUR CORE VALUES</h2>
      <div class="values-divider"></div>

      <div class="values-list">

        <div class="value-item">
          <img src="/images/SVG/1x/Recurso 24bao_.webp" alt="" aria-hidden="true" class="value-icon-img" />
          <p class="value-name">WELLNESS FIRST</p>
          <p class="value-desc">
            <strong>If it's toxic, it's out.</strong> We champion a chemical-free standard
            that protects your air quality and hormones.
          </p>
        </div>

        <div class="value-item">
          <img src="/images/SVG/1x/Recurso 24bao_.webp" alt="" aria-hidden="true" class="value-icon-img" />
          <p class="value-name">INTENTIONALITY</p>
          <p class="value-desc">
            <strong>We don't just hide clutter;</strong> we create systems that match your real habits.
          </p>
        </div>

        <div class="value-item">
          <img src="/images/SVG/1x/Recurso 24bao_.webp" alt="" aria-hidden="true" class="value-icon-img" />
          <p class="value-name">AESTHETICS</p>
          <p class="value-desc">
            <strong>We believe organization is an art form.</strong> Every shelf is styled
            to be as beautiful as it is functional.
          </p>
        </div>

      </div>
    </div>

    <div class="values-image-right">
      <img src="/images/images2/bao-23.webp" alt="Organized drawers" loading="lazy" />
    </div>
  </section>

  <!-- ── MEET THE TEAM ── -->
  <section class="meet-team">
    <div class="meet-bg"></div>
    <div class="meet-overlay"></div>
    <div class="meet-content text-center">
      <img src="/images/SVG/1x/Recurso 29bao_.webp" alt="" aria-hidden="true" class="meet-icon-img" />
      <h2 class="meet-title">MEET THE TEAM</h2>
      <p class="meet-sub">Monica &amp; Betty</p>
    </div>
  </section>

  <!-- ── PROJECTS ── -->
  <section class="projects-section">
    <div class="projects-container">

      <!-- Header -->
      <p class="projects-label">Real Transformations. Real Peace.</p>
      <h2 class="projects-title">PROJECTS</h2>
      <div class="projects-divider">
        <span class="projects-divider-line"></span>
        <img src="/images/SVG/1x/Recurso 30bao_.webp" alt="" aria-hidden="true" class="projects-divider-icon" />
        <span class="projects-divider-line"></span>
      </div>

      <!-- Project 1 -->
      <div class="project-block">
        <p class="project-title">Project Case Study 1</p>
        <div class="project-images">
          <img src="/images/SVG/1x/Recurso 32bao_.webp" alt="Project 1" loading="lazy" />
          <img src="/images/SVG/1x/Recurso 32bao_.webp" alt="Project 1" loading="lazy" />
        </div>
      </div>

      <!-- Project 2 -->
      <div class="project-block">
        <p class="project-title">Project Case Study 2</p>
        <div class="project-images">
          <img src="/images/SVG/1x/Recurso 33bao_.webp" alt="Project 2" loading="lazy" />
          <img src="/images/SVG/1x/Recurso 33bao_.webp" alt="Project 2" loading="lazy" />
        </div>
      </div>

      <!-- Project 3 -->
      <div class="project-block">
        <p class="project-title">Project Case Study 3</p>
        <div class="project-images">
          <img src="/images/SVG/1x/Recurso 34bao_.webp" alt="Project 3" loading="lazy" />
          <img src="/images/SVG/1x/Recurso 34bao_.webp" alt="Project 3" loading="lazy" />
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
/* Hero */
.hero {
  position: relative;
  height: 100vh;
  min-height: 700px;
  display: flex;
  align-items: center;
}
.hero-bg {
  position: absolute; inset: 0;
  background-image: url('/images/hero-bg.webp');
  background-size: cover;
  background-position: center;
  z-index: 0;
}
.hero-container {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 48px;
  display: flex;
  align-items: center;
  height: 100%;
}
.hero-card {
  background: rgba(255, 255, 255, 0.95);
  padding: 64px;
  max-width: 650px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
}
.hero-title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 400;
  color: var(--color-navy);
  line-height: 1.1;
  letter-spacing: 0.02em;
  margin-bottom: 24px;
  text-transform: uppercase;
}
.hero-title .text-gold {
  color: var(--color-gold);
  display: block;
  margin-top: 8px;
}
.hero-sub {
  font-family: var(--font-body);
  font-size: 1rem;
  color: var(--color-text);
  line-height: 1.6;
  margin-bottom: 40px;
  max-width: 90%;
}

@media (max-width: 768px) {
  .hero-container { padding: 0; align-items: flex-end; }
  .hero-card { width: 100%; max-width: 100%; padding: 40px 24px; }
}

/* Hello */
.hello-section {
  background: #ffffff;
  padding: 100px 0;
}
.hello-grid {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 80px;
  display: grid;
  grid-template-columns: 344px 1fr;
  gap: 80px;
  align-items: center;
}
.hello-img picture {
  display: contents;
}
.hello-img img {
  width: 344px;
  height: 344px;
  object-fit: cover;
  display: block;
}
.hello-title {
  font-family: 'Cinzel', serif;
  font-size: 39px;
  font-weight: 400;
  color: #2E394B;
  line-height: 1.1;
  margin-bottom: 12px;
}
.hello-sub {
  font-family: 'Cinzel', serif;
  font-size: 20px;
  font-weight: 400;
  color: #2E394B;
  margin-bottom: 0;
}
.hello-icon {
  margin: 24px 0 20px;
}
.hello-icon-img {
  height: 48px;
  width: auto;
  object-fit: contain;
}
.hello-body {
  font-family: 'Fivo Sans Modern', sans-serif;
  font-size: 16px;
  font-weight: 400;
  color: #4f4f59;
  line-height: 1.8;
  margin-bottom: 20px;
}
.hello-body:last-child { margin-bottom: 0; }

/* Core Values */
.section-values {
  background: #ffffff;
  display: grid;
  grid-template-columns: 1fr 560px 1fr;
  align-items: stretch;
  overflow: hidden;
}
.values-image-left,
.values-image-right {
  overflow: hidden;
}
.values-image-left img,
.values-image-right img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.values-center {
  background: #ffffff;
  padding: 80px 60px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.values-title {
  font-family: 'Cinzel', serif;
  font-size: 43px;
  font-weight: 400;
  color: #2E394B;
  text-align: center;
  letter-spacing: 0.04em;
  margin-bottom: 20px;
}
.values-divider {
  width: 60px;
  height: 1px;
  background: #D5AD7F;
  margin-bottom: 52px;
}
.values-list {
  display: flex;
  flex-direction: column;
  gap: 48px;
  width: 100%;
}
.value-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 14px;
}
.value-icon-img {
  height: 44px;
  width: auto;
  object-fit: contain;
}
.value-name {
  font-family: 'Cinzel', serif;
  font-size: 25px;
  font-weight: 400;
  color: #D5AD7F;
  letter-spacing: 0.06em;
}
.value-desc {
  font-family: 'Fivo Sans Modern', sans-serif;
  font-size: 15px;
  font-weight: 400;
  color: #4f4f59;
  line-height: 1.75;
  max-width: 340px;
}

/* Meet the Team */
.meet-team {
  position: relative;
  min-height: clamp(440px, 52vh, 640px);
  padding: 48px 24px;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}
.meet-bg {
  position: absolute; inset: 0;
  background-image: url('/images/fotos2/IMG_6280.webp');
  background-size: cover;
  background-position: center 28%;
}
.meet-overlay {
  position: absolute; inset: 0;
  background: rgba(10, 10, 10, 0.82);
}
.meet-content {
  position: relative; z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}
.meet-icon-img {
  height: 30px;
  width: 30px;
  object-fit: contain;
  margin-bottom: 10px;
}
.meet-title {
  font-family: 'Cinzel', serif;
  font-size: 44px;
  font-weight: 400;
  color: #D5AD7F;
  letter-spacing: 0.05em;
}
.meet-sub {
  font-family: 'Cinzel', serif;
  font-size: 25px;
  font-weight: 400;
  color: #ffffff;
  font-style: normal;
}

/* Projects */
.projects-section {
  background: #ffffff;
  padding: 100px 0 120px;
}
.projects-container {
  max-width: 860px;
  margin: 0 auto;
  padding: 0 32px;
  text-align: center;
}
.projects-label {
  font-family: 'Fivo Sans Modern', sans-serif;
  font-size: 18px;
  font-weight: 400;
  color: #4f4f59;
  margin-bottom: 8px;
}
.projects-title {
  font-family: 'Cinzel', serif;
  font-size: 70px;
  font-weight: 400;
  color: #2E394B;
  letter-spacing: 0.04em;
  line-height: 1;
  margin-bottom: 20px;
}
.projects-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-bottom: 64px;
}
.projects-divider-line {
  flex: 1;
  max-width: 180px;
  height: 1px;
  background: #D5AD7F;
  display: block;
}
.projects-divider-icon {
  width: 31px;
  height: 31px;
  object-fit: contain;
}
.project-block {
  margin-bottom: 64px;
}
.project-title {
  font-family: 'Cinzel', serif;
  font-size: 29px;
  font-weight: 400;
  color: #D5AD7F;
  margin-bottom: 20px;
}
.project-images {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.project-images img {
  width: 100%;
  height: 280px;
  object-fit: cover;
  display: block;
}

@media (max-width: 900px) {
  .hello-grid { grid-template-columns: 1fr; padding: 0 24px; gap: 40px; }
  .hello-title { font-size: 28px; }
  .section-values { grid-template-columns: 1fr; }
  .values-image-left, .values-image-right { display: none; }
  .values-center { padding: 60px 24px; }
  .values-title { font-size: 30px; }
  .meet-team {
    min-height: clamp(400px, 48vh, 560px);
    padding: 40px 20px;
  }
  .meet-bg { background-position: center 22%; }
  .project-images { grid-template-columns: 1fr; }
}
</style>
