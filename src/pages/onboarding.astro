---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Landing"
  description="BA Organization — Curating Homes, Cultivating Wellness."
  noFooter={true}
>

  <!-- ── LANDING: Sección aparte sin menú. Añade aquí tus bloques. ── -->

  <section class="landing-hero">
    <div class="landing-hero-container">
      <div class="landing-hero-inner">
        <img
          src="/images/landing/logo-seccion1.png"
          alt="BA Organization"
          class="landing-hero-logo"
        />
        <h1 class="landing-hero-title">
          <span class="landing-hero-title-top">CLEAR SPACES. CALM MINDS.</span>
          <span class="landing-hero-title-bottom">INTENTIONAL LIVING.</span>
        </h1>
        <a href="/contact-us" class="landing-hero-btn">
          Let’s transform your space
        </a>
      </div>
    </div>
  </section>

  <!-- ── SECCIÓN 2: THE HEART OF OUR MISSION ── -->
  <section class="landing-mission">
    <div class="landing-mission-text-col">
      <div class="landing-mission-text">
        <img
          src="/images/landing/svg/icon-seccion2.svg"
          alt=""
          class="landing-mission-icon"
        />
        <h2 class="landing-mission-title">THE HEART OF<br />OUR MISSION</h2>
        <p class="landing-mission-body landing-mission-body-bold">
          We don’t just tidy up; we build cozy, intuitive systems that tell your home’s story.
        </p>
        <p class="landing-mission-body">
          Creating harmonious, functional sanctuaries. Prioritizing your home’s aesthetic &amp; family’s health.
        </p>
        <p class="landing-mission-body">
          From a mother’s journey to your home.
        </p>
      </div>
    </div>
    <div class="landing-mission-image-col">
      <img
        src="/images/landing/imagen-seccion2.png"
        alt="BA Organization founder"
        class="landing-mission-image"
      />
    </div>
  </section>

  <!-- ── SECCIÓN 3: ORGANIZATION, ORDER & STYLE ── -->
  <section class="landing-s3">
    <div class="landing-s3-inner">
      <!-- Título -->
      <div class="landing-s3-header">
        <h2 class="landing-s3-title">
          <span class="s3-gold">ORGANIZATION,</span><span class="s3-white"> ORDER &amp; STYLE</span>
        </h2>
        <div class="landing-s3-divider"></div>
      </div>

      <!-- Mosaico 2×3 -->
      <div class="landing-s3-grid">
        <!-- Fila 1 izq: texto ORGANIZATION -->
        <div class="landing-s3-cell landing-s3-text">
          <img src="/images/landing/svg/icon-1-seccion3.svg" alt="" class="s3-icon" />
          <p class="s3-subtitle">ORGANIZATION</p>
          <p class="s3-desc">Simplify and optimize so every item has a purpose.</p>
        </div>
        <!-- Fila 1 der: imagen 1 -->
        <div class="landing-s3-cell landing-s3-img">
          <img src="/images/landing/imagen-1-seccion3.png" alt="Organization" loading="lazy" />
        </div>

        <!-- Fila 2 izq: imagen 2 -->
        <div class="landing-s3-cell landing-s3-img">
          <img src="/images/landing/imagen-2-seccion3.png" alt="Order" loading="lazy" />
        </div>
        <!-- Fila 2 der: texto ORDER -->
        <div class="landing-s3-cell landing-s3-text">
          <img src="/images/landing/svg/icon-2-seccion3.svg" alt="" class="s3-icon" />
          <p class="s3-subtitle">ORDER</p>
          <p class="s3-desc">Bring clarity and control to your environment.</p>
        </div>

        <!-- Fila 3 izq: texto STYLE -->
        <div class="landing-s3-cell landing-s3-text">
          <img src="/images/landing/svg/icon-3-seccion3.svg" alt="" class="s3-icon" />
          <p class="s3-subtitle">STYLE</p>
          <p class="s3-desc">Blending design, function, and personality.</p>
        </div>
        <!-- Fila 3 der: imagen 3 -->
        <div class="landing-s3-cell landing-s3-img">
          <img src="/images/landing/imagen-3-seccion3.png" alt="Style" loading="lazy" />
        </div>
      </div>

      <!-- Quote final -->
      <div class="landing-s3-quote-area">
        <div class="landing-s3-quote-box">
          <div class="landing-s3-quote-icon-wrapper">

            <img src="/images/landing/svg/icon-4-seccion3.svg" alt="" class="s3-icon-4" />

          </div>
          <p class="landing-s3-quote-text">AN ORGANIZED HOME IS AN ORGANIZED MIND</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SECCIÓN 4: CORE SERVICES ── -->
  <section class="landing-s4">
    <div class="landing-s4-inner">
      <!-- Título principal -->
      <div class="landing-s4-header">
        <h2 class="landing-s4-title">CORE SERVICES</h2>
        <div class="landing-s4-divider"></div>
      </div>

      <!-- Bloque A -->
      <article class="landing-s4-row">
        <div class="landing-s4-media">
          <img
            src="/images/landing/imagen-1-seccion4.png"
            alt="Curated organization & interior planning"
            loading="lazy"
          />
        </div>
        <div class="landing-s4-content">
          <div class="landing-s4-letter">A</div>
          <h3 class="landing-s4-item-title">CURATED ORGANIZATION &amp; INTERIOR PLANNING</h3>
          <p class="landing-s4-item-subtitle">
            Reclaim your time.
          </p>
          <p class="landing-s4-bullets-label">Bullet points:</p>
          <ul class="landing-s4-list">
            <li>Custom closet systems</li>
            <li>Kitchen &amp; pantry</li>
            <li>Space optimization (garage, basement)</li>
            <li>Feng Shui integration</li>
          </ul>
        </div>
      </article>

      <!-- Bloque B -->
      <article class="landing-s4-row landing-s4-row-reverse">
        <div class="landing-s4-media">
          <img
            src="/images/landing/imagen-2-seccion4.png"
            alt="Wellness-focused cleaning"
            loading="lazy"
          />
        </div>
        <div class="landing-s4-content">
          <div class="landing-s4-letter">B</div>
          <h3 class="landing-s4-item-title">WELLNESS-FOCUSED CLEANING</h3>
          <p class="landing-s4-item-subtitle">
            Safe for pets, babies, and bare feet.
          </p>
          <p class="landing-s4-bullets-label">Gráfico de “Checklist” (Lo que SÍ usamos):</p>
          <ul class="landing-s4-list">
            <li>Plant-based tools (Branch Basics, Dr. Bronner’s).</li>
            <li>Biodegradable &amp; gentle.</li>
          </ul>
          <p class="landing-s4-bullets-label">Gráfico de “Prohibido” (The “No” List):</p>
          <ul class="landing-s4-list">
            <li>No VOCs &amp; quats.</li>
            <li>No chlorine/bleach.</li>
            <li>No artificial fragrances.</li>
          </ul>
        </div>
      </article>

      <!-- Bloque C -->
      <article class="landing-s4-row">
        <div class="landing-s4-media">
          <img
            src="/images/landing/imagen-3-seccion4.png"
            alt="Seasonal & holiday styling"
            loading="lazy"
          />
        </div>
        <div class="landing-s4-content">
          <div class="landing-s4-letter">C</div>
          <h3 class="landing-s4-item-title">SEASONAL &amp; HOLIDAY STYLING</h3>
          <p class="landing-s4-item-subtitle">
            Enjoy the magic, leave the stress to us.
          </p>
          <p class="landing-s4-bullets-label">Bullet points:</p>
          <ul class="landing-s4-list">
            <li>Holiday decor installation</li>
            <li>Seasonal wardrobe swaps</li>
          </ul>
        </div>
      </article>
    </div>
  </section>

  <!-- ── SECCIÓN 5: SIGNATURE PACKAGES ── -->
  <section class="landing-s5">
    <div class="landing-s5-inner">

      <!-- Título -->
      <div class="landing-s5-header">
        <img src="/images/landing/svg/icon-seccion5.svg" alt="" class="s5-icon" />
        <h2 class="landing-s5-title">
          <span class="s5-white">SIGNATURE </span><span class="s5-gold">PACKAGES</span>
        </h2>
      </div>

      <!-- Tabla -->
      <div class="landing-s5-table">
        <!-- Cabecera -->
        <div class="landing-s5-thead">
          <div class="landing-s5-th">PACKAGE NAME</div>
          <div class="landing-s5-th">IDEAL FOR</div>
        </div>
        <!-- Filas -->
        <div class="landing-s5-tbody">

          <div class="landing-s5-row">
            <div class="landing-s5-td s5-name">The Quick Refresh</div>
            <div class="landing-s5-td s5-desc">Tackling that one nagging space (Pantry, Closet, Entryway).</div>
          </div>

          <div class="landing-s5-row">
            <div class="landing-s5-td s5-name">Pure Wellness Cleaning</div>
            <div class="landing-s5-td s5-desc">A truly non-toxic deep clean without harmful residues.</div>
          </div>

          <div class="landing-s5-row">
            <div class="landing-s5-td s5-name">The Little Ones</div>
            <div class="landing-s5-td s5-desc">Kids &amp; Play Organization designed for independence.</div>
          </div>

          <div class="landing-s5-row">
            <div class="landing-s5-td s5-name">Office Space Organization</div>
            <div class="landing-s5-td s5-desc">Enhancing focus and streamlining your workflow.</div>
          </div>

          <div class="landing-s5-row">
            <div class="landing-s5-td s5-name">The Move-In Concierge</div>
            <div class="landing-s5-td s5-desc">Relocation &amp; unpacking from day one.</div>
          </div>

          <div class="landing-s5-row">
            <div class="landing-s5-td s5-name">The Family Sanctuary</div>
            <div class="landing-s5-td s5-desc">The ultimate reset: Full organization + Deep Wellness Cleaning.</div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ── SECCIÓN 6: THE TEAM BEHIND THE VISION ── -->
  <section class="landing-s6">
    <div class="landing-s6-inner">

      <!-- Columna izquierda: título -->
      <div class="landing-s6-left">
        <h2 class="landing-s6-title">
          <span class="s6-gold">THE TEAM</span>
          <span class="s6-navy">BEHIND THE VISION</span>
        </h2>
      </div>

      <!-- Separador vertical -->
      <div class="landing-s6-divider"></div>

      <!-- Columna derecha: equipo -->
      <div class="landing-s6-right">

        <div class="landing-s6-member">
          <div class="s6-member-row">
            <img src="/images/landing/svg/icon-1-seccion6.svg" alt="" class="s6-member-icon" />
            <span>Monica Avila <strong>(Founder &amp; CEO)</strong></span>
          </div>
          <div class="s6-member-row">
            <img src="/images/landing/svg/icon-2-seccion6.svg" alt="" class="s6-email-icon" />
            <a href="mailto:Monica@baorganization.com">Monica@baorganization.com</a>
          </div>
        </div>

        <div class="landing-s6-member">
          <div class="s6-member-row">
            <img src="/images/landing/svg/icon-1-seccion6.svg" alt="" class="s6-member-icon" />
            <span>Beatriz Miranda <strong>(Co-Founder)</strong></span>
          </div>
          <div class="s6-member-row">
            <img src="/images/landing/svg/icon-2-seccion6.svg" alt="" class="s6-email-icon" />
            <a href="mailto:Monica@baorganization.com">Monica@baorganization.com</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── SECCIÓN 7: CLOSING MESSAGE ── -->
  <section class="landing-s7">
    <div class="landing-s7-inner">
      <img src="/images/landing/svg/icon-seccion7.svg" alt="" class="s7-icon" />
      <h2 class="landing-s7-title">
        <span class="s7-white">EVERYTHING IN ITS PLACE, SO</span>
        <span class="s7-gold">YOU CAN FOCUS ON WHAT MATTERS</span>
      </h2>
    </div>
  </section>

  <!-- ── FOOTER LANDING ── -->
  <footer class="landing-footer">
    <div class="landing-footer-inner">

      <!-- Logo -->
      <div class="lf-logo-wrap">
        <img
          src="/images/SVG/1x/logo_footerbao_.webp"
          alt="BA Organization"
          class="lf-logo"
        />
      </div>

      <!-- Spacer -->
      <div class="lf-spacer"></div>

      <!-- Contacto + Social -->
      <div class="lf-contact">
        <p>
          <strong>Email:</strong>
          <a href="mailto:info@baorganization.com">info@baorganization.com</a>
        </p>
        <p>
          <strong>Phone:</strong>
          <a href="tel:6787490931">(678) 749-0931</a>
        </p>
        <p><strong>Service Areas:</strong> Georgia</p>

        <div class="lf-social">
          <p class="lf-follow">Follow us</p>
          <a
            href="https://instagram.com/baorganization"
            target="_blank"
            rel="noopener"
            aria-label="Instagram"
            class="lf-ig"
          >
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#D5AD7F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4.5"/>
              <circle cx="17.5" cy="6.5" r="1" fill="#D5AD7F" stroke="none"/>
            </svg>
          </a>
        </div>
      </div>

    </div>
  </footer>

</LandingLayout>

<style>
  .landing-page main { padding-top: 0; }
  .landing-page { overflow-x: hidden; }

  .landing-hero {
    background-image: url('/images/landing/banner-seccion1.png');
    background-size: cover;
    background-position: center;
    min-height: 700px;
    display: flex;
    align-items: center;
  }
  .landing-hero-container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 700px;
  }
  .landing-hero-inner {
    text-align: center;
    color: #ffffff;
  }
  .landing-hero-logo {
    width: 120px;
    max-width: 40vw;
    margin: 0 auto 40px;
    display: block;
  }
  .landing-hero-title {
    font-family: 'Cinzel', serif;
    font-size: 45.25px;
    font-weight: 400;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: 0.08em;
    margin-bottom: 32px;
    text-transform: uppercase;
  }
  .landing-hero-title-top {
    display: block;
    color: #D5AD7F;
  }
  .landing-hero-title-bottom {
    display: block;
    color: #ffffff;
  }
  .landing-hero-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 40px;
    max-width: 90%;
  }

  .landing-content {
    padding: 96px 0;
  }

  .landing-hero-btn {
    display: inline-block;
    margin-top: 8px;
    padding: 14px 40px;
    border: none;
    cursor: pointer;
    background: #D5AD7F;
    color: #1D293C;
    font-family: 'Fivo Sans Modern', sans-serif;
    font-size: 14.26px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .landing-hero-btn:hover {
    background: #C49A6A;
  }

  /* ── Sección 2: The Heart of Our Mission ── */
  .landing-mission {
    background: #FFFFFF;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 520px;
  }

  /* Columna izquierda: texto con padding centrado */
  .landing-mission-text-col {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 80px 64px 80px 48px;
  }
  .landing-mission-text {
    width: 100%;
    max-width: 520px;
    color: #1D293C;
    text-align: left;
  }
  .landing-mission-icon {
    width: 40px;
    height: auto;
    margin-bottom: 24px;
  }
  .landing-mission-title {
    font-family: 'Cinzel', serif;
    font-size: 44px;
    font-weight: 400;
    letter-spacing: 0.08em;
    line-height: 1.1;
    text-transform: uppercase;
    color: #1D293C;
    margin-bottom: 28px;
  }
  .landing-mission-body {
    font-family: 'Fivo Sans Modern', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.7;
    color: #4F4F59;
    margin-bottom: 12px;
  }
  .landing-mission-body:last-of-type {
    margin-bottom: 0;
  }
  .landing-mission-body-bold {
    font-weight: 700;
  }

  /* Columna derecha: imagen full-bleed */
  .landing-mission-image-col {
    overflow: hidden;
  }
  .landing-mission-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  /* ── Sección 3: Organization, Order & Style ── */
  .landing-s3 {
    background-image: url('/images/landing/banner-seccion3.png');
    background-size: cover;
    background-position: center;
  }
  .landing-s3-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px 80px;
  }
  .landing-s3-header {
    text-align: center;
    padding: 80px 0 52px;
  }
  .landing-s3-title {
    font-family: 'Cinzel', serif;
    font-size: 44px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.2;
    margin-bottom: 20px;
  }
  .s3-gold  { color: #D5AD7F; }
  .s3-white { color: #ffffff; }
  .landing-s3-divider {
    width: 60px;
    height: 1px;
    background: #D5AD7F;
    margin: 0 auto;
  }

  /* Mosaico */
  .landing-s3-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }
  .landing-s3-cell {
    min-height: 380px;
  }
  .landing-s3-text {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    text-align: right;
    padding: 56px 48px;
  }
  .landing-s3-img {
    overflow: hidden;
  }
  .landing-s3-img img {
    width: 100%;
    height: 100%;
    min-height: 380px;
    object-fit: cover;
    display: block;
  }
  .s3-icon {
    width: 36px;
    height: auto;
    margin-bottom: 18px;
  }
  .s3-subtitle {
    font-family: 'Cinzel', serif;
    font-size: 31px;
    font-weight: 400;
    color: #D5AD7F;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .s3-desc {
    font-family: 'Fivo Sans Modern', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.65;
  }

  /* alternar alineación por fila: 1 derecha, 2 izquierda, 3 derecha */
  .landing-s3-grid > .landing-s3-cell:nth-child(4) .landing-s3-text {
    align-items: flex-start;
    text-align: left;
  }
  .landing-s3-grid > .landing-s3-cell:nth-child(5) .landing-s3-text {
    align-items: flex-end;
    text-align: right;
  }

  /* Quote */
  .landing-s3-quote-area {
    padding: 64px 0 0;
    text-align: center;
  }
  .landing-s3-quote-box {
    position: relative;
    display: inline-block;
    border: 1px solid #D5AD7F;
    border-top: none; /* la parte superior se dibuja con pseudo-elementos para dejar hueco bajo el icono */
    padding: 40px 64px 32px;
    max-width: 780px;
    width: 100%;
    box-sizing: border-box;
  }
  .landing-s3-quote-box::before,
  .landing-s3-quote-box::after {
    content: '';
    position: absolute;
    top: 0;
    height: 1px;
    background: #D5AD7F;
  }
  .landing-s3-quote-box::before {
    left: 0;
    width: calc(50% - 60px); /* segmento izquierdo dejando hueco al centro */
  }
  .landing-s3-quote-box::after {
    right: 0;
    width: calc(50% - 60px); /* segmento derecho dejando hueco al centro */
  }
  .landing-s3-quote-icon-wrapper {
    position: absolute;
    top: -22px;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px; /* espacio a los costados del icono */
    padding: 0 32px;
  }
  .s3-line {
    flex: 1;
    height: 1px;
    background: #D5AD7F;
  }
  .s3-icon-4 {
    width: 44px;
    height: auto;
    flex-shrink: 0;
  }
  .landing-s3-quote-text {
    font-family: 'Cinzel', serif;
    font-size: 20px;
    font-weight: 400;
    color: #ffffff;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.5;
  }

  /* ── Sección 4: Core Services ── */
  .landing-s4 {
    background: #ffffff;
  }
  .landing-s4-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 48px 100px;
  }
  .landing-s4-header {
    text-align: center;
    margin-bottom: 64px;
  }
  .landing-s4-title {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 80px; /* ~60pt */
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #1D293C;
    margin-bottom: 12px;
    line-height: 1;
  }
  .landing-s4-divider {
    width: 80px;
    height: 1px;
    margin: 0 auto;
    background: #D5AD7F;
  }

  /* Fila base: imagen izq, texto der */
  .landing-s4-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    gap: 40px;
  }
  .landing-s4-row:first-of-type {
    border-top: none;
  }

  /* Imagen */
  .landing-s4-media {
    overflow: hidden;
